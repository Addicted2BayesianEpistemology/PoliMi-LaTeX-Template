% ---------- Section page (Layout 3) ----------------------------------------
% Big steel-blue dome (huge circle, center 8.87, 0; radius 7.15) +
% small left circle outline + two horizontal lines + vertical line +
% section title between the lines + 96pt zero-padded number bottom-right.
\defbeamertemplate*{section page}{polimi}{%
  \begin{tikzpicture}[overlay, remember picture]
    \fill[polimiNavy]
      (current page.south west) rectangle (current page.north east);
    \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
      % Big dome — radial gradient: solid steel near outer edge, fading to
      % transparent at the centre (matches the original Layout 3 gradient).
      \begin{scope}
        \clip (0,0) rectangle (16,9);
        \begin{scope}
          \clip (8.85, 0) circle (7.15);
          % \shade[inner color=polimiNavy, outer color=polimiSteel, opacity=0.45]
          %   (8.87, 0) circle (7.15);
            % \shade[outer color=polimiSteel, inner color=polimiNavy, opacity=0.45]
            %     (8.85, 0) circle (7.15);
          \shade[outer color=polimiSteel, inner color=polimiNavy, opacity=0.30]
              (6.0, -0.0) circle (18.0);
        \end{scope}
      \end{scope}
      \draw[polimiPaper, opacity=0.45, line width=0.35pt] (0, 7.14) -- (16, 7.14);
      \draw[polimiPaper, opacity=0.45, line width=0.35pt] (0, 5.44) -- (16, 5.44);
      \draw[polimiPaper, opacity=0.45, line width=0.35pt] (1.68, 0) -- (1.68, 9);
      \draw[polimiPaper, opacity=0.65, line width=0.55pt]
        (0.84, 6.29) circle (0.84);
      \node[anchor=west, text=polimiPaper, align=left] at (4.22, 6.29)
        {\usebeamerfont{section title}\insertsectionhead};
      \node[anchor=south east, text=polimiPaper, inner sep=0pt]
        at (15.65, 0.85)
        {\usebeamerfont{section number}%
         \ifnum\value{section}<10 0\fi\arabic{section}};
    \end{scope}
  \end{tikzpicture}%
}

% ---------- Subsection page (Layout 5) -------------------------------------
\defbeamertemplate*{subsection page}{polimi}{%
  \begin{tikzpicture}[overlay, remember picture]
    \fill[polimiPanel]
      (current page.south west) rectangle (current page.north east);
    \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
      \draw[polimiSlate, opacity=0.55, line width=0.35pt] (0, 7.14) -- (16, 7.14);
      \draw[polimiSlate, opacity=0.55, line width=0.35pt] (0, 5.44) -- (16, 5.44);
      \draw[polimiSlate, opacity=0.55, line width=0.35pt] (1.68, 0) -- (1.68, 9);
      \draw[polimiNavy, opacity=0.75, line width=0.55pt]
        (0.84, 6.29) circle (0.84);
      \node[anchor=west, text=polimiNavy, align=left] at (4.22, 6.29)
        {\usebeamerfont{section title}\insertsubsectionhead};
      \node[anchor=south east, text=polimiNavy, inner sep=0pt]
        at (15.65, 0.85)
        {\usebeamerfont{section number}%
         \ifnum\value{section}<10 0\fi\arabic{section}.\arabic{subsection}};
    \end{scope}
  \end{tikzpicture}%
}

% ============================================================================
% ASYMMETRIC LAYOUTS  (Layouts 12 / 15 / 16 / 17 / 18 in the source)
% ============================================================================

% Image placeholder — used when the macro is called without an image path
\newcommand{\polimi@imgbox}[3]{%
  \begin{tikzpicture}
    \ifstrempty{#1}{%
      \fill[polimiFog] (0,0) rectangle (#2,#3);
      \draw[polimiSlate, dashed, line width=0.3pt] (0,0) rectangle (#2,#3);
      \node[text=polimiSlate, font=\sffamily\small] at (#2/2,#3/2) {Image placeholder};%
    }{%
      \node[anchor=south west, inner sep=0pt] at (0,0)
        {\includegraphics[width=#2 cm, height=#3 cm, keepaspectratio]{#1}};%
    }
  \end{tikzpicture}%
}

% --- 1. Asymmetric two-column (Layout 12, slide 13) -----------------------
%   \asymtextslide{title}{narrow-left content}{wide-right content}
\newcommand{\asymtextslide}[3]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiCloud]
        (current page.south west) rectangle (current page.north east);
      \fill[polimiPaper]
        (current page.south west) rectangle
        ([xshift=3.74cm]current page.north west);
    \end{tikzpicture}%
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy, align=left, text width=2.84cm]
          at (0.44, 6.84)
          {\usebeamerfont{frametitle}#1};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=2.84cm, font=\small] at (0.44, 6.30)
          {#2};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=11.34cm, font=\small] at (4.22, 6.30)
          {#3};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- 2. Text + image right (Layout 15, slide 19) --------------------------
%   \imagerightslide{title}{text}{image-path-or-empty}
\newcommand{\imagerightslide}[3]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy, align=left, text width=6.18cm]
          at (0.44, 6.84) {\usebeamerfont{frametitle}#1};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=6.18cm, font=\small] at (0.44, 6.30) {#2};
        \node[anchor=south west, inner sep=0pt] at (7.51, 0.48)
          {\polimi@imgbox{#3}{8.50}{7.45}};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- 3. Image left + text right (Layout 16, slide 20) ---------------------
%   \imageleftslide{title}{text}{image-path-or-empty}
\newcommand{\imageleftslide}[3]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, inner sep=0pt] at (1.16, 0.48)
          {\polimi@imgbox{#3}{5.71}{7.45}};
        \node[anchor=south west, text=polimiNavy, align=left, text width=7.91cm]
          at (7.66, 6.84) {\usebeamerfont{frametitle}#1};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=7.91cm, font=\small] at (7.66, 6.30) {#2};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- 4. Text + image with caption right (Layout 17, slide 21) -------------
%   \imagecaptionslide{title}{text}{image-path}{caption}
\newcommand{\imagecaptionslide}[4]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy, align=left, text width=8.03cm]
          at (0.44, 6.84) {\usebeamerfont{frametitle}#1};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=8.03cm, font=\small] at (0.44, 6.30) {#2};
        \node[anchor=south west, inner sep=0pt] at (9.62, 0.85)
          {\polimi@imgbox{#3}{5.94}{7.09}};
        \node[anchor=base west, text=polimiSlate] at (9.62, 0.51)
          {\usebeamerfont{caption}#4};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- 5. Text + two stacked images with captions (Layout 18, slide 22) -----
%   \twoimagecaptionslide{title}{text}{img1}{cap1}{img2}{cap2}
\newcommand{\twoimagecaptionslide}[6]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy, align=left, text width=8.03cm]
          at (0.44, 6.84) {\usebeamerfont{frametitle}#1};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=8.03cm, font=\small] at (0.44, 6.30) {#2};
        \node[anchor=south west, inner sep=0pt] at (9.62, 4.88)
          {\polimi@imgbox{#3}{5.94}{3.08}};
        \node[anchor=base west, text=polimiSlate] at (9.62, 4.55)
          {\usebeamerfont{caption}#4};
        \node[anchor=south west, inner sep=0pt] at (9.62, 0.85)
          {\polimi@imgbox{#5}{5.94}{3.07}};
        \node[anchor=base west, text=polimiSlate] at (9.62, 0.51)
          {\usebeamerfont{caption}#6};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% ============================================================================
% CLOSING SLIDE
% ============================================================================
\ifdefstring{\polimi@lang}{it}{%
  \def\polimi@thanks{Grazie per l'attenzione}%
}{%
  \def\polimi@thanks{Thank you for your attention}%
}

\newcommand{\closingframe}[1][\polimi@thanks]{%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiNavy]
        (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        % Two horizontal lines bracketing the text
        \draw[polimiPaper, opacity=0.45, line width=0.35pt] (0, 3.6) -- (16, 3.6);
        \draw[polimiPaper, opacity=0.45, line width=0.35pt] (0, 1.8) -- (16, 1.8);
        \draw[polimiPaper, opacity=0.45, line width=0.35pt] (1.68, 0) -- (1.68, 9);
        % Small outline circle on the left
        \draw[polimiPaper, opacity=0.65, line width=0.55pt]
          (0.84, 2.7) circle (0.84);
        % Centred text
        \node[text=polimiPaper, align=center] at (8, 2.7)
          {\usebeamerfont{section title}#1};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}



% --- Bibliography slide (full-width content) ----------------------------
%   \bibslide{title}{bibliography content}
\newcommand{\bibslide}[2]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiBibBg]
        (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \ifpolimi@showlogo
          \node[anchor=north west, inner sep=0pt] at (0.62, 8.6)
            {\includegraphics[height=1.5cm]{\polimilogodark}};
        \fi
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=14cm, font=\footnotesize] at (0.79, 6.7) {#1};
        \node[anchor=north east, text=polimiNavy, align=left,
              text width=5cm, font=\footnotesize] at (15.7, 6.5) {#2};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- Bibliography slide with image / QR code on the right ---------------
%   \bibslideimg{title}{bibliography content}{image-path}
\newcommand{\bibslideimg}[3]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiBibBg]
        (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \ifpolimi@showlogo
          \node[anchor=north west, inner sep=0pt] at (0.62, 8.6)
            {\includegraphics[height=1.5cm]{\polimilogodark}};
        \fi
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=9cm, font=\footnotesize] at (0.79, 6.7) {#1};
        \node[anchor=north east, inner sep=0pt] at (14.8, 6.7)
          {\includegraphics[width=4cm, height=4cm, keepaspectratio]{#2}};
        \node[anchor=north east, text=polimiNavy, align=left,
              text width=5cm, font=\footnotesize] at (15.7, 2.0) {#3};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}




