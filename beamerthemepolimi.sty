% --- Three-column symmetric layout -----------------------------------------
%   \threecolslide{title}{left content}{centre content}{right content}
\newcommand{\threecolslide}[4]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy] at (0.44, 7.25)
          {\usebeamerfont{frametitle}#1};
        \draw[polimiMist, line width=0.5pt] (0.00, 6.85) -- (16, 6.85);
        % Column dividers
        \draw[polimiMist, line width=0.4pt] (5.6, 0.0) -- (5.6, 6.85);
        \draw[polimiMist, line width=0.4pt] (10.56, 0.0) -- (10.56, 6.85);
        % Column content  (each ~4.84 cm wide)
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=4.84cm, font=\small] at (0.44, 6.60) {#2};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=4.64cm, font=\small] at (5.86, 6.60) {#3};
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=4.64cm, font=\small] at (10.82, 6.60) {#4};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- Full-bleed image slide -------------------------------------------------
%   \fullbleedslide[optional title overlay]{image-path}
%   The image is stretched to fill the entire slide (16:9).
%   When a title is given a semi-transparent navy strip appears at the bottom.
%   Pass an empty path to show a placeholder (useful for draft mode).
\newcommand{\fullbleedslide}[2][]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      \ifstrempty{#2}{%
        \fill[polimiFog]
          (current page.south west) rectangle (current page.north east);
        \node[text=polimiSlate, font=\sffamily\Large] at (current page.center)
          {Image placeholder};%
      }{%
        \node[anchor=center, inner sep=0pt] at (current page.center)
          {\includegraphics[width=\paperwidth, height=\paperheight]{#2}};%
      }%
      \ifstrempty{#1}{}{%
        \fill[polimiNavy, opacity=0.78]
          (current page.south west)
          rectangle ([yshift=2.0cm]current page.south east);
        \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
          \node[anchor=west, text=polimiPaper, text width=14cm]
            at (0.79, 1.0) {\usebeamerfont{frametitle}#1};
        \end{scope}
      }%
    \end{tikzpicture}%
  \end{frame}%
}

% --- Quote / highlight slide ------------------------------------------------
%   \quoteslide[attribution]{quote text}
%   Light polimiCloud background; large centred pull-quote in navy.
% Key-value defaults for \quoteslide
\pgfkeys{
  /quoteslide/.is family, /quoteslide,
  image/.store in      = \qs@image,       image      = ,
  desaturate/.store in = \qs@desaturate,  desaturate = 0,
  navyshade/.store in  = \qs@navyshade,   navyshade  = 0,
  textcolor/.store in  = \qs@textcolor,   textcolor  = polimiNavy,
}

\newcommand{\quoteslide}[3][]{%
  % #1 = key-value options, #2 = quote text, #3 = attribution (empty = none)
  \pgfkeys{/quoteslide, #1}%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      % ── Background ──────────────────────────────────────────────────────
      \ifx\qs@image\empty
        \fill[polimiCloud]
          (current page.south west) rectangle (current page.north east);
      \else
        \node[anchor=center, inner sep=0pt] at (current page.center)
          {\includegraphics[width=\paperwidth,
                            height=\paperheight,
                            keepaspectratio=false]{\qs@image}};
      \fi
      % ── Desaturation: white overlay (0 = none, 1 = fully white) ─────────
      \fill[white, opacity=\qs@desaturate]
        (current page.south west) rectangle (current page.north east);
      % ── Navy shade overlay (0 = none, 1 = fully navy) ───────────────────
      \fill[polimiNavy, opacity=\qs@navyshade]
        (current page.south west) rectangle (current page.north east);
      % ── Content ─────────────────────────────────────────────────────────
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[text=\qs@textcolor, align=center, text width=12.5cm,
              font=\fontsize{17pt}{24pt}\selectfont\sffamily]
          at (8.0, 4.9) {#2};
        \ifstrempty{#3}{}{%
          \draw[\qs@textcolor, line width=0.8pt] (6.5, 3.2) -- (9.5, 3.2);
          \node[text=\qs@textcolor, align=center,
                font=\small\itshape] at (8.0, 2.7) {#3};
        }%
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

