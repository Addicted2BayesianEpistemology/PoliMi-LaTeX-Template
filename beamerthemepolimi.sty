% --- Appendix section divider -----------------------------------------------
%   \appendixdivider[custom label]
%   Like \sectionpage but on the light polimiPanel palette to signal appendix.
\newcommand{\appendixdivider}[2][\polimi@appendixtitle]{%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiPanel]
        (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \begin{scope}
          \clip (0,0) rectangle (16,9);
          \begin{scope}
            \clip (8.85, 0) circle (7.15);
            \shade[outer color=polimiMist, inner color=polimiPanel, opacity=0.40]
              (6.0, 0.0) circle (18.0);
          \end{scope}
        \end{scope}
        \draw[polimiSlate, opacity=0.45, line width=0.35pt] (0, 7.14) -- (16, 7.14);
        \draw[polimiSlate, opacity=0.45, line width=0.35pt] (0, 5.44) -- (16, 5.44);
        \draw[polimiSlate, opacity=0.45, line width=0.35pt] (1.68, 0) -- (1.68, 9);
        \draw[polimiNavy, opacity=0.40, line width=0.55pt]
          (0.84, 6.29) circle (0.84);
        \node[anchor=west, text=polimiNavy, align=left] at (4.22, 6.29)
          {\usebeamerfont{section title}#1};
        \node[anchor=south east, text=polimiSlate, inner sep=0pt]
          at (15.65, 0.85)
          {\usebeamerfont{section number}\textit{#2}};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- Backup / extra slides marker -------------------------------------------
%   \backupmarker[custom label]
%   Dark slide clearly signalling "backup starts here"; noframenumbering so
%   the main slide count shown in the header bar is not inflated.
\newcommand{\backupmarker}[1][\polimi@backuptitle]{%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiNavyDarkHalfTitle]
        (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \draw[polimiPaper, opacity=0.25, line width=0.35pt] (0, 5.1) -- (16, 5.1);
        \draw[polimiPaper, opacity=0.25, line width=0.35pt] (0, 3.4) -- (16, 3.4);
        \draw[polimiPaper, opacity=0.25, line width=0.35pt] (1.68, 0) -- (1.68, 9);
        \draw[polimiPaper, opacity=0.40, line width=0.55pt, dashed]
          (0.84, 4.25) circle (0.84);
        \node[text=polimiPaper, align=center] at (8, 4.25)
          {\usebeamerfont{section title}#1};
        % Dashed border signals "not part of main talk"
        \draw[polimiPaper, opacity=0.18, line width=1pt, dashed]
          (0.3, 0.3) rectangle (15.7, 8.7);
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

% --- Contact / author info slide --------------------------------------------
%   \contactslide{name}{email}{institution}{photo-path}{qr-path}
%   Navy header strip + structured info block; photo and QR accept empty paths.
\newcommand{\contactslide}[5]{%
  \begin{frame}[plain]
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiPaper]
        (current page.south west) rectangle (current page.north east);
      % Navy header strip
      \fill[polimiNavy]
        (current page.north west)
        rectangle ([yshift=-1.8cm]current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \ifpolimi@showlogo
          \node[anchor=north west, inner sep=0pt] at (0.62, 8.88)
            {\includegraphics[height=1.5cm]{\polimilogowhite}};
        \fi
        % Frame counter (top right of strip)
        \node[anchor=base east, text=polimiPaper] at (15.5, 8.55)
          {\usebeamerfont{headerbar}%
           \insertframenumber/\inserttotalframenumber};
        % Name
        \node[anchor=north west, text=polimiNavy,
              font=\sffamily\fontseries{sb}\selectfont\Large] at (0.79, 6.5)
          {#1};
        % Divider
        \draw[polimiMist, line width=0.5pt] (0.79, 5.85) -- (10.5, 5.85);
        % Email
        \node[anchor=north west, text=polimiNavy, font=\small] at (0.79, 5.65)
          {\textcolor{polimiSlate}{Email}\enskip #2};
        % Institution
        \node[anchor=north west, text=polimiNavy, font=\small] at (0.79, 4.95)
          {\textcolor{polimiSlate}{Institution}\enskip #3};
        % Photo (upper right of content area)
        \node[anchor=north east, inner sep=0pt] at (15.5, 6.5)
          {\polimi@imgbox{#4}{2.9}{4.0}};
        % QR code (bottom right)
        \node[anchor=south east, inner sep=0pt] at (15.0, 1.0)
          {\polimi@imgbox{#5}{2.0}{2.8}};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

