% --- Algorithm / pseudocode slide -------------------------------------------
%   \algoslide{frame title}{explanation (left)}{pseudocode (right)}
%   Wider monospace code area on the right with a navy left-border accent.
%   Pseudocode should be written using \textbf{for}, \textbf{if}, etc.;
%   true verbatim content must be handled inside a regular frame with listings.
\newcommand{\algoslide}[3]{%
  \begin{frame}[plain]
    \polimi@headerbar
    \begin{tikzpicture}[overlay, remember picture]
      \fill[polimiCloud]
        ([xshift=5.5cm]current page.south west)
        rectangle ([yshift=-2.15cm] current page.north east);
      \draw[polimiNavy, line width=2pt]
        ([xshift=5.5cm]current page.south west)
        -- ([xshift=5.5cm, yshift=-2.15cm]current page.north west);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
        \node[anchor=south west, text=polimiNavy] at (0.44, 7.25)
          {\usebeamerfont{frametitle}#1};
        \draw[polimiMist, line width=0.5pt] (0.0, 6.85) -- (16.00, 6.85);
        % Explanation column (left)
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=4.5cm, font=\small] at (0.44, 6.60) {#2};
        % Pseudocode column (right, monospace)
        \node[anchor=north west, text=polimiNavy, align=left,
              text width=9.4cm,
              font=\ttfamily\small] at (5.8, 6.60) {#3};
      \end{scope}
    \end{tikzpicture}%
  \end{frame}%
}

