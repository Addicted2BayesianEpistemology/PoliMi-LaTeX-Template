        \node[anchor=south west, text=polimiNavy] at (0.44, 7.25)
          {\usebeamerfont{frametitle}#1};
        \draw[polimiMist, line width=0.5pt] (0.0, 6.85) -- (16.0, 6.85);
        % Column dividers
        \draw[polimiMist, line width=0.4pt] (5.33, 0.0) -- (5.33, 6.85);
        \draw[polimiMist, line width=0.4pt] (10.68, 0.0) -- (10.68, 6.85);

        % Circles behind numbers — fading out toward the bottom
        \draw[polimiFog, line width=0.8pt, path fading=south, opacity=0.8]
          (2.67,  4.2) circle (2.65);
        \draw[polimiFog, line width=0.8pt, path fading=south, opacity=0.8]
          (8.0,   4.2) circle (2.65);
        \draw[polimiFog, line width=0.8pt, path fading=south, opacity=0.8]
