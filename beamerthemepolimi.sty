          % Statistic 1
        \node[text=polimiNavy, align=center,
              font=\fontsize{32pt}{52pt}\selectfont\sffamily\fontseries{sb}\selectfont]
          at (2.73, 4.6) {#2};
        \node[text=polimiSlate, align=center, text width=4.5cm, font=\small]
          at (2.73, 2.6) {#3};
        % Statistic 2
        \node[text=polimiNavy, align=center,
              font=\fontsize{32pt}{52pt}\selectfont\sffamily\fontseries{sb}\selectfont]
          at (8.0, 4.6) {#4};
        \node[text=polimiSlate, align=center, text width=4.5cm, font=\small]
          at (8.0, 2.6) {#5};
        % Statistic 3
        \node[text=polimiNavy, align=center,
              font=\fontsize{32pt}{52pt}\selectfont\sffamily\fontseries{sb}\selectfont]
          at (13.27, 4.6) {#6};
        \node[text=polimiSlate, align=center, text width=4.5cm, font=\small]
