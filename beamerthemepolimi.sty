% beamerthemepolimi.sty
% ----------------------------------------------------------------------------
% Beamer theme inspired by the Politecnico di Milano (Ateneo) 2024 PowerPoint
% template. Geometry, colours and font sizes are taken directly from the
% slide-layout XML of the original .pptx so the layouts match the source.
%
% Recommended compiler: XeLaTeX or LuaLaTeX (so Manrope can be loaded via
%                       fontspec). pdfLaTeX works too but falls back to a
%                       generic sans font.
%
% Usage:
%   \documentclass[aspectratio=169]{beamer}
%   \usetheme{polimi}
% ----------------------------------------------------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemepolimi}[2025/01/02 v2.0 Politecnico di Milano Beamer theme]

\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=polimi,prefix=polimi@}
\DeclareStringOption[en]{lang}
\DeclareBoolOption[true]{showlogo}
\ProcessKeyvalOptions*

\RequirePackage{tikz}
\usetikzlibrary{calc,fadings,shadings,positioning,backgrounds,arrows.meta}

% Custom fading: ~85% opaque at centre, ~10% at edge — matches the
% steel-with-soft-edge look from the source .pptx
% \tikzfading[name=polimi fade,
%   inner color=transparent!15,
%   outer color=transparent!90]
\tikzfading[name=polimi fade,
  left color=transparent!15,
  right color=transparent!90]
\RequirePackage{etoolbox}
\RequirePackage{ifxetex,ifluatex}

\newif\ifpolimi@xeorlua
\ifxetex\polimi@xeorluatrue\fi
\ifluatex\polimi@xeorluatrue\fi

% ---------- Colours --------------------------------------------------------
\definecolor{polimiNavy}{HTML}{102C53}
\definecolor{polimiNavyDarkHalfTitle}{HTML}{0b1f3a} % Custom darker navy for title page title (Layout 25)
\definecolor{polimiSlate}{HTML}{596C87}
\definecolor{polimiSteel}{HTML}{8795A8}
\definecolor{polimiMist}{HTML}{B7BFCA}
\definecolor{polimiFog}{HTML}{D0D5DD}
\definecolor{polimiCloud}{HTML}{F3F3F6}
\definecolor{polimiPanel}{HTML}{DDE2E8}
\definecolor{polimiInk}{HTML}{000000}
\definecolor{polimiPaper}{HTML}{FFFFFF}
\definecolor{polimiBibBg}{HTML}{f6f4f1}

% ---------- Fonts ----------------------------------------------------------
\ifpolimi@xeorlua
  \RequirePackage{fontspec}
  \IfFileExists{./fonts/Manrope-Regular.ttf}{%
    \setsansfont{Manrope}[
      Path           = ./fonts/,
      Extension      = .ttf,
      UprightFont    = *-Regular,
      ItalicFont     = *-Regular,
      BoldFont       = *-Bold,
      BoldItalicFont = *-Bold,
      FontFace       = {l}{n}{*-Light},
      FontFace       = {m}{n}{*-Medium},
      FontFace       = {sb}{n}{*-SemiBold},
      FontFace       = {eb}{n}{*-ExtraBold},
    ]%
    \renewcommand{\familydefault}{\sfdefault}%
  }{%
    \PackageWarning{beamerthemepolimi}{%
      Manrope font files not found in ./fonts/. Falling back.%
    }%
    \renewcommand{\familydefault}{\sfdefault}%
  }
\else
  \PackageWarning{beamerthemepolimi}{%
    Compile with XeLaTeX or LuaLaTeX to use Manrope.%
  }
  \RequirePackage[T1]{fontenc}
  \RequirePackage{lmodern}
  \renewcommand{\familydefault}{\sfdefault}
\fi

% ---------- Math fonts -----------------------------------------------------
% Keep math in Computer Modern while body text stays in Manrope. Beamer's
% default font theme remaps the math 'letters' symbol font to follow the
% sans family, so without intervention math variables (x, y, n, ...) get
% rendered in Manrope while operators (\sin, \cos, ...) stay in CM — a
% jarring mix.
%
% Solution: load unicode-math (XeLaTeX/LuaLaTeX only) and explicitly bind
% math to Latin Modern Math, the unicode-math version of Computer Modern.
% This bypasses Beamer's font-theme machinery entirely. Body text is
% completely untouched and stays in Manrope.
%
% NOTE: the font is loaded by filename ('latinmodern-math.otf') rather
% than by system name ('Latin Modern Math'). On some installations
% (notably some macOS setups) fontspec's name-based lookup fails even
% when the font is installed in the TeX tree. The filename form is
% resolved by kpsewhich and works reliably on TeX Live, MacTeX, MiKTeX.
\ifpolimi@xeorlua
  \RequirePackage{unicode-math}
  \setmathfont{latinmodern-math.otf}
\fi

% --- Opt-in: render Latin math in Manrope too ------------------------------
% Call \polimimathmanrope in the preamble of your .tex BEFORE \begin{document}
% to switch math Latin letters, digits, operators (\sin, \cos, \log, ...),
% subscripts, and \mathbf to the sans text font (Manrope). Greek letters
% (\alpha, \beta, ...), large operators (\sum, \int, \prod) and math symbols
% stay in Computer Modern, because Manrope has no math-Greek or math-symbol
% glyphs at the slots TeX expects. \mathrm{...} also stays CM serif by
% design — useful for units and function labels.
\newcommand{\polimimathmanrope}{%
  \RequirePackage[italic,defaultmathsizes]{mathastext}%
}

% ---------- Logos ----------------------------------------------------------
\providecommand{\polimilogodark}{logos/Bandiera_blu.pdf}
\providecommand{\polimilogowhite}{logos/Bandiera_Bianco.pdf}
\providecommand{\polimilogotipo}{logos/Logotipo_Nero.pdf}

% ---------- Beamer base setup ----------------------------------------------
\useinnertheme{default}
\useoutertheme{default}
\setbeamertemplate{navigation symbols}{}
\setbeamercolor{normal text}{fg=polimiNavy, bg=polimiPaper}
\setbeamercolor{structure}{fg=polimiNavy}
\setbeamercolor{alerted text}{fg=polimiSlate}
\setbeamercolor{frametitle}{fg=polimiNavy, bg=polimiPaper}
\setbeamercolor{title}{fg=polimiPaper, bg=polimiNavy}
\setbeamercolor{subtitle}{fg=polimiPaper}
\setbeamercolor{author}{fg=polimiPaper}
\setbeamercolor{date}{fg=polimiPaper}
\setbeamercolor{itemize item}{fg=polimiNavy}
\setbeamercolor{itemize subitem}{fg=polimiSlate}
\setbeamercolor{enumerate item}{fg=polimiNavy}
\setbeamercolor{block title}{bg=polimiNavy, fg=polimiPaper}
\setbeamercolor{block body}{bg=polimiCloud, fg=polimiNavy}
\setbeamercolor{caption name}{fg=polimiSlate}

\setbeamertemplate{itemize item}{\color{polimiNavy}\rule[0.4ex]{0.5ex}{0.5ex}\hspace*{0.25em}}
\setbeamertemplate{itemize subitem}{\color{polimiSlate}--}

% ---------- Font sizes (taken from the layout / master XML) ----------------
\setbeamerfont{title}{family=\sffamily, series=\fontseries{sb}\selectfont, size=\fontsize{34pt}{200pt}\selectfont}
\setbeamerfont{subtitle}{family=\sffamily, series=\mdseries, size=\fontsize{13pt}{20pt}\selectfont}
\setbeamerfont{author}{family=\sffamily, size=\fontsize{8pt}{14pt}\selectfont}
\setbeamerfont{date}{family=\sffamily, size=\fontsize{8pt}{14pt}\selectfont}
\setbeamerfont{frametitle}{family=\sffamily, series=\bfseries, size=\fontsize{20pt}{10pt}\selectfont}
\setbeamerfont{section title}{family=\sffamily, series=\bfseries, size=\fontsize{18pt}{28pt}\selectfont}
% Section/subsection big number: medium weight, NOT bold (matches the original)
\setbeamerfont{section number}{family=\sffamily, series=\mdseries, size=\fontsize{60pt}{106pt}\selectfont}
\setbeamerfont{footline}{family=\sffamily, size=\fontsize{7pt}{9pt}\selectfont}
\setbeamerfont{headerbar}{family=\sffamily, size=\fontsize{5pt}{7pt}\selectfont}
\setbeamerfont{caption}{family=\sffamily, size=\fontsize{8pt}{10pt}\selectfont, shape=\itshape}

% ---------- Title page (Layout 25 in the source) ---------------------------
% Two circles vertically tangent on the line y=5.26 cm. Top one clipped by
% the top edge; bottom one mostly visible.
\newcommand{\polimisubtitle}[1]{\def\polimi@subtitle{#1}}
\def\polimi@subtitle{}

\setbeamertemplate{title page}{%
  \begin{tikzpicture}[overlay, remember picture]
    % Vertical bg gradient: black at top → navy at bottom (Layout 25 bg)
    \shade[bottom color=polimiNavy, top color=black]
      (current page.south west) rectangle (current page.north east);
    \fill[polimiNavy]
      (current page.south west) rectangle (current page.north east);
    \fill[black, path fading=south, opacity=0.7]
      (current page.south west) rectangle (current page.north east);
      \begin{scope}[shift={(current page.south west)}, x=1cm, y=1cm]
      % Decorative circles with alpha gradient (origin at the corner of each
      % circle's bounding box, fading to transparent at the far side).
      % Top circle: rotated 180° so origin is at top-left of bbox = (9.92, 5.26)
      % Bottom circle: origin at bottom-right of bbox = (15.18, -0.01)
      \begin{scope}
        \clip (0,0) rectangle (16,9);
        % \fill[polimiSteel, path fading=polimi fade, opacity=0.95]
        %   (12.55, 7.89) circle (2.63);
        % \fill[polimiSteel, path fading=polimi fade, opacity=0.95]
        %   (12.55, 2.62) circle (2.63);
        \fill[polimiSteel, path fading=polimi fade, fading angle=315, opacity=0.55]
          (12.55, 7.89) circle (2.63);
        \fill[polimiSteel, path fading=polimi fade, fading angle=135, opacity=0.55]
          (12.55, 2.62) circle (2.63);
      \end{scope}
      % Boundary lines
      \draw[polimiPaper, opacity=0.30, line width=0.3pt] (0, 5.26) -- (16, 5.26);
      \draw[polimiPaper, opacity=0.30, line width=0.3pt] (9.92, 0) -- (9.92, 9);
      \draw[polimiPaper, opacity=0.30, line width=0.3pt] (15.18, 0) -- (15.18, 9);
      % Logo
      \ifpolimi@showlogo
        \node[anchor=north west, inner sep=0pt] at (0.62, 8.6)
          {\includegraphics[height=1.5cm]{\polimilogowhite}};
      \fi
      % Optional subtitle
      \ifdefempty{\polimi@subtitle}{}{%
        \node[anchor=south west, text=polimiPaper, align=left,
              text width=8.88cm] at (0.79, 5.40)
          {\usebeamerfont{subtitle}\polimi@subtitle};%
      }
      % Title
      \node[anchor=south west, text=polimiPaper, align=left,
            text width=8.88cm] at (0.79, 2.21)
        {\usebeamerfont{title}\inserttitle};
      % Date | Author
      \node[anchor=base west, text=polimiPaper] at (0.79, 0.79)
        {\usebeamerfont{date}\insertdate
         \hspace{0.4em}\textcolor{polimiPaper!60}{$|$}\hspace{0.4em}
         \usebeamerfont{author}\insertauthor};
    \end{scope}
  \end{tikzpicture}%
}

% ---------- Header bar -----------------------------------------------------
\newcommand{\polimiheadertext}[1]{\def\polimi@headertext{#1}}
\def\polimi@headertext{Campo facoltativo e personalizzabile}

\newcommand{\polimi@headerbar}{%
  \begin{tikzpicture}[overlay, remember picture]
    \begin{scope}[shift={(current page.north west)}, x=1cm, y=1cm]
      \ifpolimi@showlogo
        \node[anchor=north west, inner sep=0pt] at (0.5,-0.25)
          {\includegraphics[height=0.3cm]{\polimilogotipo}};
      \fi
      % \draw[polimiMist, line width=0.3pt] (0.5,-0.75) -- (15.5,-0.75);
      % Center: institution + custom header text
      \node[anchor=base, text=polimiSlate] at (8,-0.45)
        {\usebeamerfont{headerbar}%
         \polimi@headertext};
      % Top-right: current/total page number
      \node[anchor=base east, text=polimiSlate] at (15.5,-0.45)
        {\usebeamerfont{headerbar}%
         \insertframenumber/\inserttotalframenumber};
    \end{scope}
  \end{tikzpicture}%
}

\setbeamertemplate{headline}{%
  \ifnum\c@framenumber>0\relax
    \polimi@headerbar
    \vspace{0.85cm}%
  \fi
}

\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[wd=\paperwidth, ht=1.0cm, dp=0.3cm,
                        leftskip=0.4cm, rightskip=0.4cm]{frametitle}%
    \usebeamerfont{frametitle}\insertframetitle%
  \end{beamercolorbox}%
}

